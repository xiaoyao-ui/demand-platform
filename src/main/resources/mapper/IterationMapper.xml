<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demand.module.project.mapper.IterationMapper">

    <!-- 结果映射 -->
    <resultMap id="IterationResultMap" type="com.demand.module.project.entity.Iteration">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="name" column="name"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="projectName" column="project_name"/>
    </resultMap>

    <!-- 查询项目下的所有迭代 -->
    <select id="selectIterationsByProjectId" resultMap="IterationResultMap">
        SELECT i.*, p.name AS project_name
        FROM sys_iteration i
        LEFT JOIN sys_project p ON i.project_id = p.id
        WHERE i.project_id = #{projectId}
        ORDER BY i.start_time DESC
    </select>

    <!-- 查询项目下的活跃迭代 -->
    <select id="selectActiveIterations" resultMap="IterationResultMap">
        SELECT i.*, p.name AS project_name
        FROM sys_iteration i
        LEFT JOIN sys_project p ON i.project_id = p.id
        WHERE i.project_id = #{projectId} AND i.status = 1
        ORDER BY i.start_time DESC
    </select>

</mapper>
