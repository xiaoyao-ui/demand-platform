<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demand.module.user.mapper.RoleMapper">

    <!-- 根据用户id查询角色信息 -->
    <select id="selectRoleKeysByUserId" resultType="java.lang.String">
        SELECT r.role_key
        FROM sys_role r
        JOIN sys_user_role ur ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
    </select>

    <!-- 根据角色key查询角色id -->
    <select id="selectRoleIdsByKeys" resultType="java.lang.Long">
        SELECT id FROM sys_role WHERE role_key IN
        <foreach collection="roleKeys" item="key" open="(" separator="," close=")">
            #{key}
        </foreach>
    </select>

    <!-- 根据角色code查询角色id -->
    <select id="selectRoleIdsByCodes" resultType="java.lang.Long">
        SELECT id FROM sys_role WHERE id IN
        <foreach collection="roleCodes" item="code" open="(" separator="," close=")">
            #{code}
        </foreach>
    </select>

    <!-- 根据角色id查询用户信息 -->
    <select id="selectUserIdsByRoleId" resultType="java.lang.Long">
        SELECT user_id FROM sys_user_role WHERE role_id = #{roleId}
    </select>

</mapper>
