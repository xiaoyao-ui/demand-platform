<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demand.module.project.mapper.ProjectMapper">

    <!-- 结果映射 -->
    <resultMap id="ProjectResultMap" type="com.demand.module.project.entity.Project">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="description" column="description"/>
        <result property="ownerId" column="owner_id"/>
        <result property="visibility" column="visibility"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="ownerName" column="owner_name"/>
    </resultMap>

    <!-- 查询项目列表 -->
    <select id="selectProjectList" resultMap="ProjectResultMap">
        SELECT p.*, u.real_name AS owner_name
        FROM sys_project p
        LEFT JOIN sys_user u ON p.owner_id = u.id
        WHERE 1=1
        <if test="keyword != null and keyword != ''">
            AND (p.name LIKE CONCAT('%', #{keyword}, '%')
            OR p.code LIKE CONCAT('%', #{keyword}, '%')
            OR p.description LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="status != null">
            AND p.status = #{status}
        </if>
        ORDER BY p.create_time DESC
    </select>

    <!-- 查询项目详情 -->
    <select id="selectProjectWithOwner" resultMap="ProjectResultMap">
        SELECT p.*, u.real_name AS owner_name
        FROM sys_project p
        LEFT JOIN sys_user u ON p.owner_id = u.id
        WHERE p.id = #{id}
    </select>

    <!-- 查询所有项目 -->
    <select id="selectAll" resultMap="ProjectResultMap">
        SELECT p.*, u.real_name AS owner_name
        FROM sys_project p
        LEFT JOIN sys_user u ON p.owner_id = u.id
        ORDER BY p.create_time DESC
    </select>

</mapper>
