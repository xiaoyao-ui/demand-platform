<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demand.module.project.mapper.ProjectModuleMapper">

    <!-- 结果映射 -->
    <resultMap id="ProjectModuleResultMap" type="com.demand.module.project.entity.ProjectModule">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="description" column="description"/>
        <result property="parentId" column="parent_id"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 根据项目ID查询获取所有模块信息 -->
    <select id="selectModulesByProjectId" resultMap="ProjectModuleResultMap">
        SELECT * FROM project_module
        WHERE project_id = #{projectId}
        ORDER BY sort ASC, id ASC
    </select>

    <!-- 根据项目ID查询获取启用的模块信息 -->
    <select id="selectActiveModulesByProjectId" resultMap="ProjectModuleResultMap">
        SELECT * FROM project_module
        WHERE project_id = #{projectId} AND status = 1
        ORDER BY sort ASC, id ASC
    </select>

    <!-- 根据父级模块ID查询获取子级模块信息 -->
    <select id="selectChildModules" resultMap="ProjectModuleResultMap">
        SELECT * FROM project_module
        WHERE parent_id = #{parentId}
        ORDER BY sort ASC, id ASC
    </select>

</mapper>
